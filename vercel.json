{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "https://aiconsultingsa.com/",
      "permanent": true
    },
    {
      "source": "/ai-phone-answering/index.html",
      "destination": "https://aiconsultingsa.com/ai-phone-answering/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.aiconsultingsa.com" }],
      "destination": "https://aiconsultingsa.com/:path*",
      "permanent": true
    }
  ]
}
